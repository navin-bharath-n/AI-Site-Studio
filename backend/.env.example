# Backend environment variables example
# Copy this file to .env and fill in your values

# ──────────────────────────────────────
# Application
# ──────────────────────────────────────
APP_NAME="AI Site Studio"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development   # development | staging | production

# ──────────────────────────────────────
# Database (PostgreSQL / Supabase)
# ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://<username>:<password>@<host>:<port>/<database>

# ──────────────────────────────────────
# Redis
# ──────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────
# Security
# ──────────────────────────────────────
SECRET_KEY=generate_a_random_32_character_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
REFRESH_TOKEN_EXPIRE_DAYS=30

# ──────────────────────────────────────
# OAuth (Google / Facebook / GitHub)
# ──────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ──────────────────────────────────────
# AI Providers (OpenAI / Gemini)
# ──────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Separate Gemini models per feature
GEMINI_MODEL_AI_CHAT_ASSISTANT=gemini-3.5-flash
GEMINI_MODEL_WEBSITE_CONTENT_GENERATION=gemini-3.5-flash
GEMINI_MODEL_SEO_GENERATOR=gemini-3.5-flash
GEMINI_MODEL_SEMANTIC_SEARCH=gemini-embedding-2
GEMINI_MODEL_TEMPLATE_RECOMMENDATION=gemini-embedding-2
GEMINI_MODEL_ACCESSIBILITY_REVIEW=gemini-3.5-flash
GEMINI_MODEL_CODE_ASSISTANT=gemini-3.5-flash
GEMINI_MODEL_PROJECT_ZIP_ANALYSIS=gemini-3.5-flash
GEMINI_MODEL_TRANSLATION=gemini-3.5-flash
GEMINI_MODEL_BUSINESS_ANALYSIS=gemini-3.5-flash
GEMINI_MODEL_LOGO_IDEAS=gemini-3.5-flash
GEMINI_MODEL_IMAGE_GENERATION=flux
GEMINI_MODEL_OCR_DOCUMENT_UNDERSTANDING=gemini-3.5-flash

# Alternative models per feature
ALT_MODEL_AI_CHAT_ASSISTANT=gpt-4o-mini
ALT_MODEL_WEBSITE_CONTENT_GENERATION=gpt-4o-mini
ALT_MODEL_SEO_GENERATOR=gpt-4o-mini
ALT_MODEL_SEMANTIC_SEARCH=cohere-embed
ALT_MODEL_TEMPLATE_RECOMMENDATION=cohere-embed
ALT_MODEL_ACCESSIBILITY_REVIEW=gpt-4o
ALT_MODEL_CODE_ASSISTANT=gpt-4.1
ALT_MODEL_PROJECT_ZIP_ANALYSIS=gpt-4.1
ALT_MODEL_TRANSLATION=gpt-4o-mini
ALT_MODEL_BUSINESS_ANALYSIS=gpt-4o
ALT_MODEL_LOGO_IDEAS=gpt-4o
ALT_MODEL_IMAGE_GENERATION=stable-diffusion-xl
ALT_MODEL_OCR_DOCUMENT_UNDERSTANDING=gpt-4o

# ── Azure OpenAI (Fallback / Alternate) ──
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Optional deployment mappings (fallbacks if blank)
AZURE_DEPLOYMENT_CHAT=
AZURE_DEPLOYMENT_AI_CHAT_ASSISTANT=
AZURE_DEPLOYMENT_WEBSITE_CONTENT_GENERATION=
AZURE_DEPLOYMENT_SEO_GENERATOR=
AZURE_DEPLOYMENT_SEMANTIC_SEARCH=
AZURE_DEPLOYMENT_TEMPLATE_RECOMMENDATION=
AZURE_DEPLOYMENT_ACCESSIBILITY_REVIEW=
AZURE_DEPLOYMENT_CODE_ASSISTANT=
AZURE_DEPLOYMENT_PROJECT_ZIP_ANALYSIS=
AZURE_DEPLOYMENT_TRANSLATION=
AZURE_DEPLOYMENT_BUSINESS_ANALYSIS=
AZURE_DEPLOYMENT_LOGO_IDEAS=
AZURE_DEPLOYMENT_IMAGE_GENERATION=
AZURE_DEPLOYMENT_OCR_DOCUMENT_UNDERSTANDING=

# ──────────────────────────────────────
# Qdrant Vector Database
# ──────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=templates

# ──────────────────────────────────────
# File Storage (PostgreSQL / R2)
# ──────────────────────────────────────
STORAGE_BACKEND=postgres
STORAGE_BASE_URL=http://localhost:8000/api/v1/files

# ──────────────────────────────────────
# Cloudflare R2 Storage (Optional)
# ──────────────────────────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=ai-site-studio
# R2_PUBLIC_URL=

# ──────────────────────────────────────
# Payments (Razorpay / Stripe)
# ──────────────────────────────────────
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# ──────────────────────────────────────
# CORS & Domains
# ──────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ──────────────────────────────────────
# File Upload Limits
# ──────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# ──────────────────────────────────────
# Supabase Integration (Optional)
# ──────────────────────────────────────
SUPABASE_URL=your-supabase-project-url
SUPABASE_KEY=your-supabase-anon-key
